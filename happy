def dcf_valuation(hist,driver_forecast):
    projs=driver_forecast.get("projections",[]); last=hist[-1]
    wacc=0.10; terminal_growth=0.025; da_pct=0.03; capex_pct=0.04; tax_rate=0.21; wc_pct=0.05
    fcfs=[]
    for p in projs:
        rev=p["revenue"]; ebit=p["net_income"]; nopat=ebit*(1-tax_rate)
        da=rev*da_pct; capex=rev*capex_pct
        delta_wc=(rev-(projs[projs.index(p)-1]["revenue"] if projs.index(p)>0 else last["total_revenue"]))*wc_pct
        fcfs.append(round(nopat+da-capex-delta_wc,2))
    pv_fcfs=[round(f/(1+wacc)**(i+1),2) for i,f in enumerate(fcfs)]; sum_pv=sum(pv_fcfs)
    terminal_ni=projs[-1]["net_income"] if projs else last["net_income"]
    terminal_rev=projs[-1]["revenue"] if projs else last["total_revenue"]
    terminal_fcf=terminal_ni*(1-tax_rate)+terminal_rev*da_pct-terminal_rev*capex_pct
    terminal_value=round(terminal_fcf*(1+terminal_growth)/(wacc-terminal_growth),2)
    pv_terminal=round(terminal_value/(1+wacc)**len(projs),2)
    enterprise_value=round(sum_pv+pv_terminal,2)
    net_debt=last["total_liabilities"]-sum(v for k,v in last["ledger"]["assets"].items() if "cash" in k.lower())
    equity_value=round(enterprise_value-max(net_debt,0),2)
    sensitivity={}
    for w in [0.08,0.09,0.10,0.11,0.12]:
        pv_tv=round(terminal_fcf*(1+terminal_growth)/(w-terminal_growth)/(1+w)**len(projs),2)
        sensitivity[f"WACC {w*100:.0f}%"]=round(sum(f/(1+w)**(i+1) for i,f in enumerate(fcfs))+pv_tv-max(net_debt,0),2)
    return {"method":"DCF","assumptions":{"wacc":wacc,"terminal_growth_rate":terminal_growth,"tax_rate":tax_rate,"projection_years":len(projs)},
        "free_cash_flows":fcfs,"pv_of_fcfs":pv_fcfs,"sum_pv_fcfs":round(sum_pv,2),
        "terminal_value":terminal_value,"pv_terminal_value":pv_terminal,"enterprise_value":enterprise_value,
        "net_debt":round(net_debt,2),"equity_value":equity_value,
        "equity_value_range":{"low":round(equity_value*0.8,2),"base":equity_value,"high":round(equity_value*1.2,2)},
        "wacc_sensitivity":sensitivity}

def risk_analysis(hist,ratios,cashflow):
    last_ratio=ratios[-1] if ratios else {}; last=hist[-1] if hist else {}; L=last.get("ledger",{})
    rev_items=list(L.get("revenue",{}).items()) if L else []
    top_rev=max(v for _,v in rev_items) if rev_items else 0
    total_rev=sum(v for _,v in rev_items) if rev_items else 1
    rev_concentration=safe_div(top_rev,total_rev)
    cr=last_ratio.get("current_ratio",2); de=last_ratio.get("debt_to_equity",0)
    nm=last_ratio.get("net_margin",0); runway=cashflow.get("current_runway_months",99); wc=last_ratio.get("working_capital",0)
    risks={
        "revenue_concentration":{"score":"Low" if rev_concentration<0.5 else "Medium" if rev_concentration<0.75 else "High","value":round(rev_concentration,3),"detail":"Single revenue stream dominates" if rev_concentration>0.75 else "Revenue appears diversified"},
        "liquidity_risk":{"score":"Low" if cr>=2 else "Medium" if cr>=1.5 else "High" if cr>=1 else "Critical","current_ratio":round(cr,2),"detail":"Liquidity is strained" if cr<1.5 else "Adequate liquidity"},
        "debt_risk":{"score":"High" if de>4 else "Medium" if de>2 else "Low","debt_to_equity":round(de,2),"detail":"Highly leveraged" if de>4 else "Manageable debt load"},
        "margin_compression":{"score":"High" if nm<0.03 else "Medium" if nm<0.10 else "Low","net_margin":round(nm,4),"detail":"Thin margins leave little buffer for cost increases"},
        "cash_burn_risk":{"score":"Critical" if runway<6 else "High" if runway<12 else "Medium" if runway<24 else "Low","runway_months":runway,"detail":f"At current burn rate, {runway:.0f} months of cash remaining"},
        "working_capital_risk":{"score":"High" if wc<0 else "Medium" if wc<last.get("total_revenue",1)*0.1 else "Low","working_capital":round(wc,2),"detail":"Negative working capital" if wc<0 else "Working capital adequate"},
    }
    scores={"Low":1,"Medium":2,"High":3,"Critical":4}
    avg_score=statistics.mean([scores.get(r["score"],2) for r in risks.values()])
    overall="Low Risk" if avg_score<1.5 else "Medium Risk" if avg_score<2.5 else "High Risk" if avg_score<3.5 else "Critical Risk"
    return {"overall_risk_rating":overall,"composite_score":round(avg_score,2),"risks":risks}

