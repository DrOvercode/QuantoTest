def build_income_statement(L,company,period):
    wb=Workbook(); ws=wb.active; ws.title="Income Statement"
    set_w(ws,{"A":38,"B":2,"C":16})
    wt(ws,1,company,"C"); wt(ws,2,"Income Statement","C",bg=TEAL,sz=12)
    ws2(ws,3,f"For the Period Ended {period}","C",bg=TEAL)
    cogs_keys=[k for k in L["expenses"] if "cost" in k.lower() or "cogs" in k.lower()]
    opex_keys=[k for k in L["expenses"] if k not in cogs_keys]
    r=5; wsec(ws,r,"REVENUE","C"); r+=1; rs=r
    for nm,v in L["revenue"].items(): witem(ws,r,nm,v,bg=LGRAY if r%2==0 else WHITE); r+=1
    re_=r; wtotal(ws,r,"Total Revenue",formula=f"=SUM(C{rs}:C{r-1})"); r+=2
    wsec(ws,r,"COST OF GOODS SOLD","C"); r+=1; cs=r
    for nm in cogs_keys: witem(ws,r,nm,L["expenses"][nm],bg=LGRAY if r%2==0 else WHITE); r+=1
    if not cogs_keys: witem(ws,r,"(none)",0,bg=LGRAY); r+=1
    ct=r; wtotal(ws,r,"Total COGS",formula=f"=SUM(C{cs}:C{r-1})",bg=ORANGE); r+=1
    gp=r; wtotal(ws,r,"GROSS PROFIT",formula=f"=C{re_}-C{ct}",bg=LTBLUE); r+=2
    wsec(ws,r,"OPERATING EXPENSES","C"); r+=1; os_=r
    for nm in opex_keys: witem(ws,r,nm,L["expenses"][nm],bg=LGRAY if r%2==0 else WHITE); r+=1
    if not opex_keys: witem(ws,r,"(none)",0,bg=LGRAY); r+=1
    ot=r; wtotal(ws,r,"Total Operating Expenses",formula=f"=SUM(C{os_}:C{r-1})",bg=ORANGE); r+=2
    oi=r; wtotal(ws,r,"OPERATING INCOME",formula=f"=C{gp}-C{ot}",bg=LTBLUE); r+=1
    wtotal(ws,r,"NET INCOME",formula=f"=C{oi}",bg=GREEN)
    return wb

