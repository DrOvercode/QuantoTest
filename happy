def confidence_scoring(hist,ratios):
    n=len(hist); revenues=[h["total_revenue"] for h in hist]
    volatility=round(statistics.stdev(revenues)/statistics.mean(revenues)*100,1) if len(revenues)>1 and statistics.mean(revenues) else 50
    data_completeness="High" if n>=5 else "Medium" if n>=3 else "Low"
    rev_conf="High" if volatility<15 and n>=4 else "Medium" if volatility<30 else "Low"
    margins=[r["gross_margin"] for r in ratios if r.get("gross_margin")]
    margin_vol=round(statistics.stdev(margins)*100,1) if len(margins)>1 else 20
    margin_conf="High" if margin_vol<5 else "Medium" if margin_vol<15 else "Low"
