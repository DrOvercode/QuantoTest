async function runConsolidation(){
  if(entities.length<1){alert('Add at least one entity.');return;}
  const parentName=document.getElementById('parentNameInput').value.trim()||'Group Consolidated';
  const period=document.getElementById('consolPeriod').value.trim()||'Current Period';
  const standard=document.getElementById('consolStandard').value;
  const optMinority=document.getElementById('optMinority').checked;
  const optGoodwill=document.getElementById('optGoodwill').checked;
  const optCurrencyNorm=document.getElementById('optCurrencyNorm').checked;
  const optSegment=document.getElementById('optSegment').checked;
  const optRatios=document.getElementById('optRatios').checked;
  const optAiNarr=document.getElementById('optAiNarr').checked;

  const btn=document.getElementById('consolBtn');btn.disabled=true;
  const statusArea=document.getElementById('cstatus-area');
  statusArea.style.display='block';
  const steps=[
    'Step 1: Extracting & OCR-reading all entity trial balances...',
    'Step 2: Normalizing account names across entities...',
    'Step 3: Validating trial balance integrity per entity...',
    'Step 4: Applying ownership % and computing NCI allocations...',
    'Step 5: Processing intercompany eliminations...',
    'Step 6: Auto-detecting suspected intercompany balances...',
    'Step 7: Calculating Goodwill on acquisition...',
    'Step 8: Aggregating consolidated trial balance...',
    'Step 9: Building consolidated Income Statement...',
    'Step 10: Building consolidated Balance Sheet...',
    'Step 11: Building Statement of Changes in Equity...',
    'Step 12: Computing group-level financial ratios...',
    'Step 13: Generating per-entity segment report...',
    'Step 14: Running AI narrative engine (Llama 3.1)...',
    'Step 15: Assembling multi-tab Excel consolidation package...',
  ];
  statusArea.innerHTML='<div class="progress-card">'+steps.map(s=>`<div class="step-item active"><span class="spinner"></span>${s}</div>`).join('')+'</div>';
  document.getElementById('cresult-area').innerHTML='';

  const fd=new FormData();
  fd.append('parent_name',parentName);
  fd.append('period',period);
  fd.append('standard',standard);
  fd.append('options',JSON.stringify({minority:optMinority,goodwill:optGoodwill,normalize:optCurrencyNorm,segment:optSegment,ratios:optRatios,ai_narrative:optAiNarr}));
  fd.append('eliminations',JSON.stringify(eliminations.map(e=>({type:e.type,amount:e.amount,description:e.description,debit_entity:e.debit_entity,credit_entity:e.credit_entity}))));
  entities.forEach(ent=>{fd.append('entities',ent.file,`${ent.name}||${ent.ownership}||${ent.file.name}`);});

  try{
    const resp=await fetch('/api/consolidate',{method:'POST',body:fd});
    const data=await resp.json();
    if(!resp.ok) throw new Error(data.detail||'Unknown error');
    statusArea.innerHTML='';
    const warnings=(data.warnings||[]).map(w=>`<p style="color:var(--orange);font-size:.78rem;margin-top:.35rem">⚠ ${w}</p>`).join('');
    const elims=(data.eliminations_applied||[]).map(e=>`<li style="font-size:.78rem;color:var(--text-muted)">${e}</li>`).join('');
    document.getElementById('cresult-area').innerHTML=`
      <div class="result-card consol-result">
        <div style="font-size:2.2rem">🏢</div>
        <h2 style="margin:.6rem 0;font-size:1.35rem">${parentName} — Consolidated Financial Statements</h2>
        <p style="color:var(--text-muted);font-size:.9rem">${period} · ${standard} · <strong>${data.entity_count} entities</strong></p>
        <p style="color:var(--text-dim);font-size:.78rem;margin-top:.4rem">
          ${data.total_accounts_extracted} accounts extracted · ${data.eliminations_count} eliminations applied · OCR: ${data.ocr_provider}
        </p>
        ${warnings}
        ${elims?`<ul style="margin-top:.5rem;text-align:left;padding-left:1.5rem">${elims}</ul>`:''}
        <a href="/api/download/${data.filename}" class="download-btn" style="background:linear-gradient(135deg,var(--gold),#e0a820);color:#1a1000;box-shadow:0 4px 20px rgba(245,200,66,0.25)">
          ⬇ Download Consolidation Package
        </a>
      </div>`;
  }catch(err){
    statusArea.innerHTML='';
    document.getElementById('cresult-area').innerHTML=`<div class="result-card" style="border-color:var(--red)">
      <div style="font-size:1.8rem">❌</div><h3 style="color:var(--red);margin:.5rem 0">Error</h3>
      <p style="color:var(--text-muted);font-size:.88rem">${err.message}</p>
    </div>`;
  }
  btn.disabled=false;
}

