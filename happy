def chat_with_ollama(message: str, history: list, analytics: dict, company: str, period: str) -> str:
    context = f"""Company: {company}\nPeriod: {period}
Revenue: ${analytics.get('revenue',0):,.0f}\nGross Profit: ${analytics.get('gross_profit',0):,.0f} ({analytics.get('gross_margin',0)*100:.1f}%)
Net Income: ${analytics.get('net_income',0):,.0f} ({analytics.get('net_margin',0)*100:.1f}%)
EBITDA: ${analytics.get('ebitda',0):,.0f} ({analytics.get('ebitda_margin',0)*100:.1f}%)
Total Assets: ${analytics.get('total_assets',0):,.0f}\nTotal Liabilities: ${analytics.get('total_liabilities',0):,.0f}
Total Equity: ${analytics.get('total_equity',0):,.0f}\nCurrent Ratio: {analytics.get('current_ratio',0):.2f}x
Quick Ratio: {analytics.get('quick_ratio',0):.2f}x\nDebt-to-Equity: {analytics.get('debt_to_equity',0):.2f}x
ROE: {analytics.get('roe',0)*100:.1f}%\nROA: {analytics.get('roa',0)*100:.1f}%
Working Capital: ${analytics.get('working_capital',0):,.0f}"""
    system = CHAT_SYSTEM+f"\n\nFINANCIAL DATA:\n{context}"
    messages = [{"role":"system","content":system}]
    for h in history[-8:]: messages.append({"role":h["role"],"content":h["content"]})
    messages.append({"role":"user","content":message})
    try:
        import ollama
        resp = ollama.chat(model=OLLAMA_MODEL,messages=messages,options={"temperature":0.3,"num_predict":1024})
        return resp["message"]["content"].strip()
    except Exception as e:
        return f"Unable to connect to AI engine. Ensure Ollama is running with llama3.1. Error: {e}"


