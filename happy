    "sales":"Revenue","turnover":"Revenue","net sales":"Revenue","revenue":"Revenue",
    "rent expense":"Rent Expense","office rent":"Rent Expense","lease expense":"Rent Expense",
    "utilities":"Utilities Expense","electricity":"Utilities Expense","power":"Utilities Expense",
