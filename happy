def extract_text(file_bytes: bytes, filename: str) -> str:
    provider = OCR_PROVIDER; errors = []
    if provider == "gemini" and GEMINI_API_KEY:
        try: return _extract_text_gemini(file_bytes, filename)
        except Exception as e: errors.append(f"Gemini: {e}")
    if provider in ("openai","gemini") and OPENAI_API_KEY:
        try: return _extract_text_openai(file_bytes, filename)
