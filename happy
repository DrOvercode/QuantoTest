def _pdf_to_images_base64(file_bytes: bytes) -> list:
    try:
        from PIL import Image as PILImage
        try:
            from pdf2image import convert_from_bytes
            images = convert_from_bytes(file_bytes, dpi=300)
            result = []
            for img in images[:8]:
                buf = io.BytesIO(); img.save(buf, format="PNG")
                result.append(base64.b64encode(buf.getvalue()).decode())
            return result
        except ImportError:
            pass
    except Exception:
        pass
    return []

def _image_to_base64(file_bytes: bytes, filename: str) -> str:
    return base64.b64encode(file_bytes).decode()

def _extract_text_local(file_bytes: bytes, filename: str) -> str:
    ext = Path(filename).suffix.lower()
    if ext == ".pdf":
        try:
            import pdfplumber
            pages = []
            with pdfplumber.open(io.BytesIO(file_bytes)) as pdf:
                for page in pdf.pages:
                    tables = page.extract_tables()
                    if tables:
                        for table in tables:
                            for row in table:
                                pages.append("\t".join(str(c or "").strip() for c in row))
                    txt = page.extract_text()
                    if txt: pages.append(txt)
            return "\n".join(pages)
        except ImportError:
            raise HTTPException(500, "pdfplumber not installed.")
    else:
        try:
            import pytesseract
            from PIL import Image as PILImage
            img = PILImage.open(io.BytesIO(file_bytes))
            w, h = img.size
            if w < 1200:
                sc = 2400 / w; img = img.resize((int(w*sc), int(h*sc)), PILImage.LANCZOS)
            img = img.convert("L")
            return pytesseract.image_to_string(img, config="--psm 6 --oem 3")
        except ImportError:
            raise HTTPException(500, "pytesseract/pillow not installed.")

def _extract_text_gemini(file_bytes: bytes, filename: str) -> str:
    if not GEMINI_API_KEY: raise ValueError("GEMINI_API_KEY not set")
    try:
        import google.generativeai as genai
        genai.configure(api_key=GEMINI_API_KEY)
        model = genai.GenerativeModel("gemini-1.5-pro")
        ext = Path(filename).suffix.lower()
        if ext == ".pdf":
            response = model.generate_content([genai.upload_blob(file_bytes, mime_type="application/pdf"), VISION_PROMPT])
        else:
            from PIL import Image as PILImage
            img = PILImage.open(io.BytesIO(file_bytes)); w, h = img.size
            if w < 2000:
                sc = 2400/w; img = img.resize((int(w*sc), int(h*sc)), PILImage.LANCZOS)
            buf = io.BytesIO(); img.save(buf, format="PNG")
            img_part = {"mime_type": "image/png", "data": base64.b64encode(buf.getvalue()).decode()}
            response = model.generate_content([img_part, VISION_PROMPT])
        return response.text
    except Exception as e:
        raise RuntimeError(f"Gemini OCR failed: {e}")

def _extract_text_openai(file_bytes: bytes, filename: str) -> str:
    if not OPENAI_API_KEY: raise ValueError("OPENAI_API_KEY not set")
    try:
        from openai import OpenAI
        client = OpenAI(api_key=OPENAI_API_KEY)
        ext = Path(filename).suffix.lower()
        messages = [{"role":"user","content":[{"type":"text","text":VISION_PROMPT}]}]
        if ext == ".pdf":
            images_b64 = _pdf_to_images_base64(file_bytes)
            if not images_b64:
                text = _extract_text_local(file_bytes, filename)
                resp = client.chat.completions.create(model="gpt-4o",messages=[{"role":"user","content":f"{VISION_PROMPT}\n\n{text}"}],max_tokens=4096,temperature=0)
                return resp.choices[0].message.content
            for b64 in images_b64[:4]:
                messages[0]["content"].append({"type":"image_url","image_url":{"url":f"data:image/png;base64,{b64}","detail":"high"}})
        else:
            from PIL import Image as PILImage
            img = PILImage.open(io.BytesIO(file_bytes)); w, h = img.size
            if w < 2000:
                sc = 2400/w; img = img.resize((int(w*sc), int(h*sc)), PILImage.LANCZOS)
            buf = io.BytesIO(); img.save(buf, format="PNG")
            b64 = base64.b64encode(buf.getvalue()).decode()
            messages[0]["content"].append({"type":"image_url","image_url":{"url":f"data:image/png;base64,{b64}","detail":"high"}})
        resp = client.chat.completions.create(model="gpt-4o",messages=messages,max_tokens=4096,temperature=0)
        return resp.choices[0].message.content
    except Exception as e:
        raise RuntimeError(f"OpenAI OCR failed: {e}")

