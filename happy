def wt(ws,row,text,lc="D",bg=NAVY,fg=WHITE,sz=13):
    n=lc if isinstance(lc,int) else ord(lc)-64
    ws.merge_cells(start_row=row,start_column=1,end_row=row,end_column=n)
    c=ws.cell(row,1,text); c.font=Font(name="Calibri",bold=True,size=sz,color=fg)
    c.fill=hfill(bg); c.alignment=center(); ws.row_dimensions[row].height=22

def ws2(ws,row,text,lc="D",bg=BLUE):
    n=lc if isinstance(lc,int) else ord(lc)-64
    ws.merge_cells(start_row=row,start_column=1,end_row=row,end_column=n)
    c=ws.cell(row,1,text); c.font=bfont(11,WHITE); c.fill=hfill(bg); c.alignment=center()
    ws.row_dimensions[row].height=18

def wsec(ws,row,text,lc="D",bg=LTBLUE):
    n=lc if isinstance(lc,int) else ord(lc)-64
    ws.merge_cells(start_row=row,start_column=1,end_row=row,end_column=n)
    c=ws.cell(row,1,text); c.font=bfont(10,NAVY); c.fill=hfill(bg); c.alignment=left()

def witem(ws,row,label,value=None,formula=None,bold=False,bg=WHITE,ind=3,col=3):
    cl=ws.cell(row,1,label)
    cl.font=bfont(10,NAVY) if bold else rfont(10)
    cl.alignment=Alignment(horizontal="left",vertical="center",indent=0 if bold else ind)
    cl.fill=hfill(bg)
    for ci in range(2,col): ws.cell(row,ci).fill=hfill(bg)
    cv=ws.cell(row,col); cv.alignment=right(); cv.number_format=money(); cv.fill=hfill(bg)
    if formula: cv.value=formula; cv.font=rfont(10)
    elif value is not None: cv.value=value; cv.font=Font(name="Calibri",size=10,color="00008B")
    ws.row_dimensions[row].height=16

def wtotal(ws,row,label,value=None,formula=None,bg=GREEN,col=3,ncols=None):
    nc=ncols or col
    for ci in range(1,nc+1): ws.cell(row,ci).fill=hfill(bg); ws.cell(row,ci).border=tb()
    cl=ws.cell(row,1,label); cl.font=bfont(10,NAVY); cl.alignment=left(0); cl.fill=hfill(bg)
    cv=ws.cell(row,col); cv.font=bfont(10,NAVY); cv.alignment=right(); cv.number_format=money(); cv.fill=hfill(bg)
    if formula: cv.value=formula
    elif value is not None: cv.value=value
    ws.row_dimensions[row].height=17

def set_w(ws,widths):
    for col,w in widths.items(): ws.column_dimensions[col].width=w

def _ms_header(ws,company,title,subtitle,ncols=5):
    lc=chr(64+ncols)
    set_w(ws,{chr(65+i):20 for i in range(ncols)}); ws.column_dimensions["A"].width=38
    wt(ws,1,company,lc); wt(ws,2,title,lc,bg=TEAL,sz=12); ws2(ws,3,subtitle,lc,bg=TEAL)

def _frow(ws,row,label,values,bold=False,bg=WHITE,fmt=None,col_start=2):
    cl=ws.cell(row,1,label)
    cl.font=bfont(10,NAVY) if bold else rfont(10)
    cl.alignment=Alignment(horizontal="left",vertical="center",indent=0 if bold else 2)
    cl.fill=hfill(bg)
    for i,v in enumerate(values):
        c=ws.cell(row,col_start+i); c.alignment=right(); c.fill=hfill(bg); c.number_format=fmt or money()
        if v is not None:
            c.value=round(float(v),2) if isinstance(v,(int,float)) else v
