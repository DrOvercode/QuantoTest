def normalize_account_name(name):
    lower=name.lower().strip()
    for pattern,normalized in NORMALIZE_MAP.items():
        if pattern in lower: return normalized
    return name.strip()

def validate_historical_data(years_data):
    errors=[]; warnings=[]; passed=True
    if len(years_data)<3:
        errors.append(f"Only {len(years_data)} year(s) provided. Minimum required: 3 years."); passed=False
    for i,yd in enumerate(years_data):
        yr=yd.get("period","Year "+str(i+1)); accts=yd.get("accounts",[])
        if not accts: errors.append(f"{yr}: No accounts extracted."); passed=False; continue
        total_dr=sum(float(a.get("debit",0) or 0) for a in accts)
        total_cr=sum(float(a.get("credit",0) or 0) for a in accts)
        if abs(total_dr-total_cr)>1:
            errors.append(f"{yr}: TB out of balance — DR ${total_dr:,.0f} vs CR ${total_cr:,.0f}"); passed=False
        rev=sum(float(a.get("credit",0) or 0) for a in accts if a.get("type")=="revenue")
        assets=sum(float(a.get("debit",0) or 0) for a in accts if a.get("type")=="asset")
        liab=sum(float(a.get("credit",0) or 0) for a in accts if a.get("type")=="liability")
        eq=sum(float(a.get("credit",0) or 0) for a in accts if a.get("type")=="equity")
        if assets>0 and abs(assets-(liab+eq))>assets*0.05:
            warnings.append(f"{yr}: Balance sheet variance > 5%")
        if rev==0: warnings.append(f"{yr}: No revenue accounts detected.")
    return {"passed":passed,"errors":errors,"warnings":warnings}

def build_historical_ledgers(years_data):
    result=[]
    for yd in years_data:
        accts=yd.get("accounts",[])
        normalized=[{**a,"name":normalize_account_name(a.get("name",""))} for a in accts]
        L=build_ledger(normalized)
        result.append({
            "period":yd.get("period","Unknown"),"company":yd.get("company_name","Unknown"),
            "ledger":L,"accounts":normalized,
            "total_revenue":sum(L["revenue"].values()),"total_expenses":sum(L["expenses"].values()),
            "net_income":_net_income(L),"total_assets":sum(L["assets"].values()),
            "total_liabilities":sum(L["liabilities"].values()),"total_equity":_total_equity(L),
            "gross_profit":sum(L["revenue"].values())-_cogs(L),"cogs":_cogs(L),"dividends":_dividends(L),
        })
    return result

def calc_historical_ratios(hist):
    ratios=[]
    for h in hist:
        L=h["ledger"]; rev=h["total_revenue"]; ni=h["net_income"]; ta=h["total_assets"]
        tl=h["total_liabilities"]; te=h["total_equity"]; gp=h["gross_profit"]; cg=h["cogs"]
        ca=sum(_cur_assets(L).values()); cl=sum(_cur_liab(L).values())
        cash=sum(v for k,v in L["assets"].items() if "cash" in k.lower())
        ar=sum(v for k,v in L["assets"].items() if "receivable" in k.lower())
        inv=sum(v for k,v in L["assets"].items() if "inventory" in k.lower())
        ap=sum(v for k,v in L["liabilities"].items() if "payable" in k.lower())
        int_exp=sum(v for k,v in L["expenses"].items() if "interest" in k.lower())
        ebit=rev-sum(L["expenses"].values())+int_exp
        ratios.append({"period":h["period"],"revenue_growth":None,
            "gross_margin":safe_div(gp,rev),"operating_margin":safe_div(ni+int_exp,rev),
            "net_margin":safe_div(ni,rev),"current_ratio":safe_div(ca,cl),
            "quick_ratio":safe_div(cash+ar,cl),"debt_to_equity":safe_div(tl,te),
            "interest_coverage":safe_div(ebit,int_exp) if int_exp else 999,
            "roa":safe_div(ni,ta),"roe":safe_div(ni,te),"asset_turnover":safe_div(rev,ta),
            "inventory_turnover":safe_div(cg,inv) if inv else 0,
            "receivable_turnover":safe_div(rev,ar) if ar else 0,
            "working_capital":ca-cl,"raw":h})
    for i in range(1,len(ratios)):
        prev=hist[i-1]["total_revenue"]; curr=hist[i]["total_revenue"]
        ratios[i]["revenue_growth"]=safe_div(curr-prev,prev) if prev else None
    return ratios

def cagr(start,end,years):
    if start and start>0 and end and years>0: return (end/start)**(1/years)-1
    return 0.0

def weighted_growth(values):
    if len(values)<2: return 0.0
    growths=[]
    for i in range(1,len(values)):
        if values[i-1] and values[i-1]!=0: growths.append((values[i]-values[i-1])/values[i-1])
    if not growths: return 0.0
    weights=[2**i for i in range(len(growths))]
    return sum(g*w for g,w in zip(growths,weights))/sum(weights)

def forecast_growth_rates(hist,years_forward=5):
    revenues=[h["total_revenue"] for h in hist]; expenses=[h["total_expenses"] for h in hist]; n=len(hist)
    rev_cagr=cagr(revenues[0],revenues[-1],n-1) if n>1 else 0
    rev_wgr=weighted_growth(revenues); exp_cagr=cagr(expenses[0],expenses[-1],n-1) if n>1 else 0
    rev_rate=0.4*rev_cagr+0.6*rev_wgr; exp_rate=0.4*exp_cagr+0.6*weighted_growth(expenses)
    base_rev=revenues[-1]; base_exp=expenses[-1]; forecasts={}
    for horizon in [1,3,5]:
        proj=[]
        for yr in range(1,horizon+1):
            pr=base_rev*(1+rev_rate)**yr; pe=base_exp*(1+exp_rate)**yr
            proj.append({"year":yr,"revenue":round(pr,2),"expenses":round(pe,2),"net_income":round(pr-pe,2),"gross_margin":safe_div(pr-pe*0.4,pr)})
        forecasts[f"{horizon}yr"]={"revenue_growth_rate_applied":round(rev_rate,6),"expense_growth_rate_applied":round(exp_rate,6),"cagr_used":round(rev_cagr,6),"weighted_growth_used":round(rev_wgr,6),"projections":proj}
    return {"method":"Growth Rate Forecast (CAGR + Weighted)","assumptions":{"revenue_cagr":rev_cagr,"weighted_growth":rev_wgr,"blended_rate":rev_rate},"forecasts":forecasts}

def forecast_driver_based(hist):
    revenues=[h["total_revenue"] for h in hist]; expenses=[h["total_expenses"] for h in hist]; n=len(hist)
    rev_growth=weighted_growth(revenues)
    avg_exp_pct=statistics.mean([safe_div(expenses[i],revenues[i]) for i in range(n) if revenues[i]>0])
    ratios=calc_historical_ratios(hist)
    avg_gross_margin=statistics.mean([r["gross_margin"] for r in ratios]) if ratios else 0.5
    avg_net_margin=statistics.mean([r["net_margin"] for r in ratios]) if ratios else 0.1
    drivers={
        "revenue":{"driver":"Revenue Growth Rate (blended)","value":round(rev_growth,4),"logic":"Weighted average of YoY growth rates"},
        "cogs":{"driver":"COGS as % of Revenue","value":round(1-avg_gross_margin,4),"logic":"Historical average gross margin applied inversely"},
        "opex":{"driver":"OpEx as % of Revenue","value":round(avg_exp_pct-(1-avg_gross_margin),4),"logic":"Total expense ratio minus COGS ratio"},
        "receivables":{"driver":"Receivable Turnover (times)","value":round(ratios[-1]["receivable_turnover"],2) if ratios else 0,"logic":"Last historical year turnover ratio"},
    }
    base_rev=revenues[-1] if revenues else 0
    projections=[{"year":yr,"revenue":round(base_rev*(1+rev_growth)**yr,2),"cogs":round(base_rev*(1+rev_growth)**yr*(1-avg_gross_margin),2),"gross_profit":round(base_rev*(1+rev_growth)**yr*avg_gross_margin,2),"total_expenses":round(base_rev*(1+rev_growth)**yr*avg_exp_pct,2),"net_income":round(base_rev*(1+rev_growth)**yr*avg_net_margin,2)} for yr in range(1,6)]
    return {"method":"Driver-Based Forecast","drivers":drivers,"projections":projections,"assumptions":{"avg_gross_margin":avg_gross_margin,"avg_exp_pct":avg_exp_pct,"rev_growth_rate":rev_growth}}

def forecast_time_series(hist):
    revenues=[h["total_revenue"] for h in hist]; n=len(revenues)
    xs=list(range(n)); xm=statistics.mean(xs); ym=statistics.mean(revenues)
    num=sum((x-xm)*(y-ym) for x,y in zip(xs,revenues)); den=sum((x-xm)**2 for x in xs) or 1
    slope=num/den; intercept=ym-slope*xm
    lin_proj=[{"year":yr,"revenue":round(intercept+slope*(n+yr-1),2),"method":"Linear Trend"} for yr in range(1,6)]
    alpha=0.3; smoothed=revenues[0]
    for v in revenues[1:]: smoothed=alpha*v+(1-alpha)*smoothed
    growth=slope/ym if ym else 0
    exp_proj=[{"year":yr,"revenue":round(smoothed*(1+growth*0.7)**yr,2),"method":"Exponential Smoothing"} for yr in range(1,6)]
    ma=statistics.mean(revenues[-3:]) if len(revenues)>=3 else statistics.mean(revenues)
    ma_proj=[{"year":yr,"revenue":round(ma*(1+growth)**yr,2),"method":"Moving Average"} for yr in range(1,6)]
    return {"method":"Time Series Forecast",
        "linear_regression":{"slope":round(slope,2),"intercept":round(intercept,2),"projections":lin_proj},
        "exponential_smoothing":{"alpha":alpha,"last_smoothed":round(smoothed,2),"projections":exp_proj},
        "moving_average":{"periods":3,"base":round(ma,2),"projections":ma_proj},
        "trend_direction":"Upward" if slope>0 else "Downward",
        "detected_volatility":round(statistics.stdev(revenues)/ym*100,1) if len(revenues)>1 and ym else 0}

def build_three_statement_model(hist,driver_forecast):
    last=hist[-1]; L=last["ledger"]; proj=driver_forecast.get("projections",[])
    linked=[]; prev_re=_total_equity(L)-sum(v for k,v in L["equity"].items() if "stock" in k.lower() or "capital" in k.lower())
    prev_assets=last["total_assets"]; cash=sum(v for k,v in L["assets"].items() if "cash" in k.lower())
    for p in proj:
        ni=p["net_income"]; rev=p["revenue"]
        da=rev*0.03; wc_change=-(rev-last["total_revenue"])*0.05
        op_cf=ni+da+wc_change; inv_cf=-(rev*0.04); div=ni*0.1
        fin_cf=-div; net_cf=op_cf+inv_cf+fin_cf; ending_cash=cash+net_cf
        total_assets=prev_assets*(1+(rev-last["total_revenue"])/last["total_revenue"]*0.6) if last["total_revenue"] else prev_assets
        re=prev_re+ni-div
        stock=sum(v for k,v in L["equity"].items() if "stock" in k.lower() or "capital" in k.lower())
        total_liab=total_assets-re-stock
        linked.append({"year":p["year"],"revenue":rev,"net_income":ni,
            "income_statement":{"revenue":rev,"cogs":p["cogs"],"gross_profit":p["gross_profit"],"total_expenses":p["total_expenses"],"net_income":ni},
            "cash_flow":{"operating":round(op_cf,2),"investing":round(inv_cf,2),"financing":round(fin_cf,2),"net_change":round(net_cf,2),"ending_cash":round(ending_cash,2),"depreciation_addback":round(da,2),"capex":round(inv_cf,2),"dividends_paid":round(-div,2)},
            "balance_sheet":{"projected_total_assets":round(total_assets,2),"retained_earnings":round(re,2),"total_equity":round(re+stock,2),"total_liabilities":round(total_liab,2),"check_balanced":abs(total_assets-(total_liab+re+stock))<100}})
        cash=ending_cash; prev_re=re; prev_assets=total_assets
    return {"method":"Three-Statement Linked Model","linked_projections":linked,
        "assumptions":{"da_pct_rev":0.03,"capex_pct_rev":0.04,"div_payout_pct_ni":0.10,"wc_change_sensitivity":0.05}}

def forecast_cashflow(hist,three_stmt):
    projs=three_stmt.get("linked_projections",[])
    cash_positions=[p["cash_flow"]["ending_cash"] for p in projs]
    monthly_burn=hist[-1]["total_expenses"]/12 if hist else 0
    current_cash=sum(v for k,v in hist[-1]["ledger"]["assets"].items() if "cash" in k.lower()) if hist else 0
    runway_months=round(current_cash/monthly_burn,1) if monthly_burn>0 else 999
    runs_out=any(c<0 for c in cash_positions)
    runs_out_year=next((p["year"] for p in projs if p["cash_flow"]["ending_cash"]<0),None)
    return {"current_cash_position":round(current_cash,2),"monthly_operating_burn":round(monthly_burn,2),
        "current_runway_months":runway_months,"projected_cash_positions":cash_positions,
        "will_run_out_of_cash":runs_out,"estimated_shortfall_year":runs_out_year,
        "minimum_financing_needed":round(abs(min(cash_positions)),2) if runs_out else 0,
        "cash_flow_summary":[{"year":p["year"],"operating":p["cash_flow"]["operating"],"investing":p["cash_flow"]["investing"],"financing":p["cash_flow"]["financing"],"ending_cash":p["cash_flow"]["ending_cash"]} for p in projs]}

