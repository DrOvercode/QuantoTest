def build_ledger(accounts: list) -> dict:
    L = {"assets":{},"liabilities":{},"equity":{},"revenue":{},"expenses":{},"dividends":{}}
    for a in accounts:
        name=a.get("name",""); dr=float(a.get("debit",0) or 0); cr=float(a.get("credit",0) or 0)
        t=a.get("type","").lower()
        if   t=="asset":     L["assets"][name]=dr
        elif t=="liability": L["liabilities"][name]=cr
        elif t=="equity":    L["equity"][name]=cr
        elif t=="revenue":   L["revenue"][name]=cr
        elif t=="expense":   L["expenses"][name]=dr
        elif t=="dividend":  L["dividends"][name]=dr
    return L

def safe_div(n,d): return round(n/d,6) if d and d!=0 else 0.0
def _cur_assets(L):
    kw=["cash","receivable","inventory","prepaid","short","market"]
    return {k:v for k,v in L["assets"].items() if any(x in k.lower() for x in kw)}
def _nca(L):
    ca=_cur_assets(L); return {k:v for k,v in L["assets"].items() if k not in ca}
def _cur_liab(L):
    kw=["payable","accrued","current","tax","short","deferred rev"]
    return {k:v for k,v in L["liabilities"].items() if any(x in k.lower() for x in kw)}
def _ncl(L):
    cl=_cur_liab(L); return {k:v for k,v in L["liabilities"].items() if k not in cl}
def _net_income(L): return sum(L["revenue"].values())-sum(L["expenses"].values())
def _dividends(L): return sum(L["dividends"].values())
def _total_equity(L):
    ni=_net_income(L); div=_dividends(L)
    stock=sum(v for k,v in L["equity"].items() if "stock" in k.lower() or "capital" in k.lower())
    opening_re=sum(v for k,v in L["equity"].items() if "retained" in k.lower())
    return stock+opening_re+ni-div
def _cogs(L): return sum(v for k,v in L["expenses"].items() if "cost" in k.lower() or "cogs" in k.lower())

