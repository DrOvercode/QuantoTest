# ANALYTICS
# ─────────────────────────────────────────────────────────────────────────────
def compute_analytics(L: dict, accounts: list) -> dict:
    rev=sum(L["revenue"].values()); cogs=_cogs(L); gp=rev-cogs; ni=_net_income(L)
    ta=sum(L["assets"].values()); tl=sum(L["liabilities"].values()); te=_total_equity(L)
    ca=sum(_cur_assets(L).values()); cl=sum(_cur_liab(L).values()); nca=sum(_nca(L).values())
    cash=sum(v for k,v in L["assets"].items() if "cash" in k.lower())
    ar=sum(v for k,v in L["assets"].items() if "receivable" in k.lower())
    inv=sum(v for k,v in L["assets"].items() if "inventory" in k.lower())
    ap=sum(v for k,v in L["liabilities"].items() if "payable" in k.lower() and "tax" not in k.lower())
    int_exp=sum(v for k,v in L["expenses"].items() if "interest" in k.lower())
    dep_exp=sum(v for k,v in L["expenses"].items() if "depreci" in k.lower() or "amort" in k.lower())
    opex=sum(L["expenses"].values())-cogs; ebit=ni+int_exp; ebitda=ebit+dep_exp
    op_inc=gp-opex; wc=ca-cl; invested_capital=te+tl-(ta-ca-nca)
    nopat=ebit*(1-0.21); op_cf_est=ni+dep_exp
    debt_svc=int_exp+sum(v for k,v in L["liabilities"].items() if "current" in k.lower() and "portion" in k.lower())
    return {
        "revenue":rev,"cogs":cogs,"gross_profit":gp,"net_income":ni,"total_assets":ta,
        "total_liabilities":tl,"total_equity":te,"ebitda":ebitda,
        "gross_margin":safe_div(gp,rev),"net_margin":safe_div(ni,rev),
        "operating_margin":safe_div(op_inc,rev),"ebitda_margin":safe_div(ebitda,rev),
        "current_ratio":safe_div(ca,cl),"quick_ratio":safe_div(cash+ar,cl),
        "cash_ratio":safe_div(cash,cl),"working_capital":wc,"working_capital_ratio":safe_div(ca,cl),
        "roa":safe_div(ni,ta),"roe":safe_div(ni,te),"roic":safe_div(nopat,max(invested_capital,1)),
        "asset_turnover":safe_div(rev,ta),"inventory_turnover":safe_div(cogs,inv) if inv else None,
        "ar_turnover":safe_div(rev,ar) if ar else None,"ap_turnover":safe_div(cogs,ap) if ap else None,
        "wc_turnover":safe_div(rev,wc) if wc and wc>0 else None,
        "fixed_asset_turnover":safe_div(rev,nca) if nca else None,
        "debt_to_equity":safe_div(tl,te),"debt_ratio":safe_div(tl,ta),
        "interest_coverage":safe_div(ebit,int_exp) if int_exp else None,
        "dscr":safe_div(op_cf_est,debt_svc) if debt_svc else None,
        "equity_ratio":safe_div(te,ta),"ocf_ratio":safe_div(op_cf_est,cl) if cl else None,
        "cf_coverage":safe_div(op_cf_est,tl) if tl else None,
        "fcf_ratio":safe_div(op_cf_est-(rev*0.04),rev) if rev else None,
        "cash_conversion":safe_div(op_cf_est,ni) if ni and ni!=0 else None,
        "rev_growth":None,"gp_growth":None,"ebitda_growth":None,"ni_growth":None,"cf_growth":None,
        "pe_ratio":None,"ps_ratio":None,"ev_ebitda":None,"pb_ratio":None,
        "mrr":round(rev/12,2) if rev>0 else None,"arr":round(rev,2) if rev>0 else None,
    }

